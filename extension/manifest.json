{
  "manifest_version": 3,
  "name": "Etsy Product Shortlister",
  "version": "2.1.0",
  "description": "Find trending Etsy products bought in the past 24 hours",
  "permissions": ["storage", "scripting", "tabs", "nativeMessaging"],
  "host_permissions": [
    "https://www.etsy.com/*",
    "https://etsy-shortlister-production-3d4e.up.railway.app/*",
    "http://localhost:*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://etsy-shortlister-production-3d4e.up.railway.app/*",
        "http://localhost:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
